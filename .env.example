# ============================================
# 精神避难所 — 环境变量模板
# 复制为 .env.local 并填入实际值
# ============================================

# --- 数据库 (MySQL) ---
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=spiritualrefuge
DATABASE_PASSWORD=your_db_password_here
DATABASE_NAME=spiritualrefuge

# --- JWT ---
JWT_SECRET=your_jwt_secret_here_change_me
SESSION_MAX_AGE=604800

# --- AI (智谱 GLM-5V-Turbo) ---
# API Key: https://open.bigmodel.cn
DEEPSEEK_API_KEY=your-zhipu-api-key
DEEPSEEK_BASE_URL=https://open.bigmodel.cn/api/paas/v4
DEEPSEEK_MODEL=glm-5v-turbo

# --- Vercel Blob (生产环境文件存储) ---
# https://vercel.com/storage/blob
BLOB_READ_WRITE_TOKEN=

# --- 短信/邮件（内测阶段不启用） ---
ALIBABA_SMS_ACCESS_KEY_ID=
ALIBABA_SMS_ACCESS_KEY_SECRET=
ALIBABA_SMS_SIGN_NAME=精神避难所
ALIBABA_SMS_TEMPLATE_CODE=
RESEND_API_KEY=

# --- 管理员 ---
ADMIN_EMAIL=admin@example.com

# --- 内测 ---
SKIP_VERIFICATION=true
SITE_URL=http://localhost:3000
SITE_NAME=精神避难所
