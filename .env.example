# ============================================
# 社交媒体焦虑分析工具 — 环境变量模板
# 复制为 .env.local 并填入实际值
# ============================================

# --- 数据库 ---
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=spiritualrefuge
DATABASE_PASSWORD=your_db_password_here
DATABASE_NAME=spiritualrefuge

# --- JWT / Session ---
JWT_SECRET=your_jwt_secret_here_change_me
SESSION_MAX_AGE=604800

# --- DeepSeek AI ---
# 多模态 API，Key 由你自行填写
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 阿里云短信（内测阶段不启用） ---
ALIBABA_SMS_ACCESS_KEY_ID=
ALIBABA_SMS_ACCESS_KEY_SECRET=
ALIBABA_SMS_SIGN_NAME=精神避难所
ALIBABA_SMS_TEMPLATE_CODE=

# --- Resend 邮件（内测阶段不启用） ---
RESEND_API_KEY=

# --- 管理员 ---
ADMIN_EMAIL=admin@example.com

# --- 上传 ---
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=uploads

# --- 站点 ---
SITE_URL=http://localhost:3000
SITE_NAME=精神避难所

# --- 内测模式 ---
# true = 跳过验证码发送（内测阶段）
SKIP_VERIFICATION=true
